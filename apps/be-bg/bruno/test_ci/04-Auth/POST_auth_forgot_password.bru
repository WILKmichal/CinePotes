meta {
  name: POST /auth/forgot-password
  type: http
  seq: 17
}

post {
  url: {{URL}}/auth/forgot-password
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "email": "bruno@test.fr"
  }
}

tests {
  test("Status code is 200 or 201", function() {
    const status = res.getStatus();
    expect(status).to.be.oneOf([200, 201]);
  });

  test("Response contains message", function() {
    expect(res.body).to.have.property('message');
  });
}
