meta {
  name: GET /seances/{id}/participants
  type: http
  seq: 4
}

get {
  url: {{URL}}/seances/{{SEANCE_ID}}/participants
  body: none
  auth: bearer
}

auth:bearer {
  token: {{ACCESS_TOKEN}}
}

script:pre-request {
  await bru.runRequest("06-Seances/POST_seances");
}

tests {
  test("Status code is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("Response is an array", function() {
    expect(res.body).to.be.an('array');
  });
}
