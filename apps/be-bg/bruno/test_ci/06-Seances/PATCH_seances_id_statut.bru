meta {
  name: PATCH /seances/{id}/statut
  type: http
  seq: 5
}

patch {
  url: {{URL}}/seances/{{SEANCE_ID}}/statut
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
}

auth:bearer {
  token: {{ACCESS_TOKEN}}
}

body:json {
  {
    "statut": "en_cours"
  }
}

script:pre-request {
  await bru.runRequest("06-Seances/POST_seances");
}

tests {
  test("Status code is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("Response contains statut", function() {
    expect(res.body).to.have.property('statut');
  });
}
