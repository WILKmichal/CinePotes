meta {
  name: DELETE /seances/{id}/leave
  type: http
  seq: 6
}

delete {
  url: {{URL}}/seances/{{SEANCE_ID}}/leave
  body: none
  auth: bearer
}

auth:bearer {
  token: {{ACCESS_TOKEN}}
}

script:pre-request {
  await bru.runRequest("06-Seances/POST_seances");
}

tests {
  test("Status code is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("Response contains message", function() {
    expect(res.body).to.have.property('message');
  });
}
